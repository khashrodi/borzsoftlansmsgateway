<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/borzsoft_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BorzSoft"
                android:textColor="@color/borzsoft_highlight"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFFLINE"
                android:textColor="@color/status_offline"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status_badge"/>

        </LinearLayout>

        <!-- Server IP Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/borzsoft_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gateway Address"
                    android:textColor="@color/borzsoft_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="http://0.0.0.0:8080"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tv_sms_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMS Today: 0"
                    android:textColor="@color/borzsoft_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <Button
                    android:id="@+id/btn_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Start Gateway"
                    android:backgroundTint="@color/borzsoft_highlight"
                    android:textColor="@color/white"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- QR Code Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/borzsoft_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web Access – QR Login"
                    android:textColor="@color/borzsoft_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_gravity="start"/>

                <ImageView
                    android:id="@+id/iv_qr"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/white"
                    android:padding="8dp"
                    android:contentDescription="QR Code"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan with browser or enter token manually"
                    android:textColor="@color/borzsoft_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tv_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/borzsoft_highlight"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:ellipsize="middle"
                    android:singleLine="true"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btn_refresh_token"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="New QR"
                        android:backgroundTint="@color/borzsoft_accent"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btn_revoke_all"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Revoke All"
                        android:backgroundTint="@color/status_offline"
                        android:textColor="@color/white"
                        android:textSize="13sp"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SMS Log Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/borzsoft_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent SMS Logs"
                    android:textColor="@color/borzsoft_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <ListView
                    android:id="@+id/lv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:dividerHeight="1dp"
                    android:divider="@color/borzsoft_accent"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
