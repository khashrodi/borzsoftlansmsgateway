<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Server Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_server"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gateway Server" android:textColor="@color/on_surface"
                        android:textSize="16sp" android:textStyle="bold"/>

                    <TextView android:id="@+id/tv_status_badge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="● OFFLINE" android:textColor="@color/status_offline"
                        android:textSize="12sp" android:textStyle="bold"
                        android:paddingHorizontal="12dp" android:paddingVertical="6dp"
                        android:background="@drawable/bg_badge_offline"/>

                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="URL" android:textColor="@color/on_surface_muted"
                    android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.1"/>

                <TextView android:id="@+id/tv_gateway_url"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gateway not running"
                    android:textColor="@color/on_surface" android:textSize="15sp"
                    android:fontFamily="monospace" android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_toggle"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Start Gateway"
                        app:backgroundTint="@color/accent"
                        android:textColor="@color/white"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_refresh"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:text="↻"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/card_stroke"
                        android:textColor="@color/on_surface_muted"
                        app:cornerRadius="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_settings"
                        android:layout_width="48dp" android:layout_height="48dp"
                        android:text="⚙"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/card_stroke"
                        android:textColor="@color/on_surface_muted"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">

            <!-- SMS Today -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tv_sms_today"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/accent"
                        android:textSize="32sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SMS TODAY" android:textColor="@color/on_surface_muted"
                        android:textSize="10sp" android:letterSpacing="0.1" android:textAllCaps="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sent -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tv_sms_sent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/status_online"
                        android:textSize="32sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SENT" android:textColor="@color/on_surface_muted"
                        android:textSize="10sp" android:letterSpacing="0.1" android:textAllCaps="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Failed -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginStart="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tv_sms_failed"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/status_offline"
                        android:textSize="32sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="FAILED" android:textColor="@color/on_surface_muted"
                        android:textSize="10sp" android:letterSpacing="0.1" android:textAllCaps="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Sessions Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:padding="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ACTIVE WEB SESSIONS"
                        android:textColor="@color/on_surface_muted" android:textSize="11sp"
                        android:letterSpacing="0.1" android:textAllCaps="true"/>
                    <TextView android:id="@+id/tv_active_sessions"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/primary"
                        android:textSize="28sp" android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌐" android:textSize="32sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
